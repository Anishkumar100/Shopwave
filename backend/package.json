{
  "name": "mern-ecommerce-backend",
  "version": "1.0.0",
  "description": "Full MERN E-Commerce Backend with Cashfree Payment Gateway",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed:products": "node seeders/productSeeder.js",
    "seed:users": "node seeders/userSeeder.js",
    "seed:all": "node seeders/productSeeder.js && node seeders/userSeeder.js",
    "seed:destroy": "node seeders/productSeeder.js --destroy"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cashfree-pg": "^3.0.1",
    "colors": "^1.4.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "slugify": "^1.6.6",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "cloudinary": "^1.41.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}